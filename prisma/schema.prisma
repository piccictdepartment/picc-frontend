generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Donation {
  id        Int      @id @default(autoincrement())
  amount    Float
  donorName String?
  email     String?
  method    String?
  createdAt DateTime @default(now())
}

model PrayerRequest {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  request    String
  isPrivate  Boolean  @default(true)
  isAnswered Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dayOfWeek   String
  startTime   String
  endTime     String?
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Testimony {
  id          Int      @id @default(autoincrement())
  name        String
  title       String?
  content     String
  imageUrl    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Giving {
  id               Int       @id @default(autoincrement())
  bookletNumber    String?
  givingDate       DateTime?
  givingType       String?
  specialRecipient String?
  amount           Float
  currency         String    @default("MWK")
  fullName         String
  email            String?
  phone            String
  phoneCountry     String    @default("+265")
  paymentMethod    String    @default("airtel")
  reason           String?
  status           String    @default("pending") // pending, completed, failed
  transactionId    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  startTime   String?
  endTime     String?
  location    String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Sermon {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  pastor      String?
  date        DateTime
  duration    String?
  isPublished Boolean       @default(true)
  createdAt   DateTime      @default(now())
  media       SermonMedia[]
}

model SermonMedia {
  id        Int      @id @default(autoincrement())
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  sermonId  Int
  url       String
  type      String?
  createdAt DateTime @default(now())
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  name      String
  password  String
  role      String        @default("user") // "user" or "admin"
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  content   String
  videoId   String // YouTube videoId to group messages by stream
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
